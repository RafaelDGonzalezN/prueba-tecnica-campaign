      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) return [];\n\nlet campaignList = \"🚨 **LISTADO DE CAMPAÑAS EN ESTADO CRÍTICO** 🚨\\n\\n\";\n\nitems.forEach(item => {\n  const data = item.json;\n  campaignList += `• **ID:** ${data.id} | ${data.name} | ${data.metric}\\n`;\n});\n\nreturn [{\n  json: {\n    texto_discord: campaignList\n  }\n}];"
      },
