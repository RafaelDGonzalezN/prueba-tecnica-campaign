    {
      "parameters": {
        "jsCode": "const item = $input.all()[0].json;\n\nconst errorMessage = item.error?.message || \"Ocurrió un error inesperado al procesar los datos del webhook.\";\n\nlet alerta = \"⚠️ **ALERTA DE ERROR: REPORTE DE CAMPAÑAS** ⚠️\\n\\n\";\nalerta += `**Motivo del fallo:** \\n> ${errorMessage}\\n\\n`;\nalerta += \"Revisa la fuente que envía el Webhook, la data de `campaignSummary` no llegó correctamente.\";\n\nreturn [{\n  json: {\n    texto_discord: alerta,\n    error_status: true\n  }\n}];"
      },
