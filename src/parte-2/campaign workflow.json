    {
      "parameters": {
        "jsCode": "const item = $input.all()[0].json;\n\nif (!item.body || !item.body.campaignSummary) {\n  throw new Error(\"Fallo crítico: El webhook no envió el objeto campaignSummary.\");\n}\n\nconst summaryData = item.body.campaignSummary;\n\nif (summaryData.summary.includes(\"No se pudo generar el resumen\") || summaryData.rawResponse === \"User not found.\") {\n  const motivoError = summaryData.rawResponse || \"Error de conexión o parseo con la IA.\";\n  throw new Error(`Fallo interno del LLM: ${motivoError}`);\n}\n\nconst summary = summaryData.summary || \"Sin resumen\";\nconst criticalCampaigns = [...new Set(summaryData.criticalCampaigns || [])]; \nconst suggestedActions = summaryData.suggestedActions || [];\n\nlet texto = \"📊 **REPORTE DE CAMPAÑAS**\\n\\n\";\n\ntexto += `**📝 Summary:**\\n> ${summary}\\n\\n`;\n\ntexto += \"**🚨 Critical Campaigns:**\\n\";\nif (criticalCampaigns.length > 0) {\n  criticalCampaigns.forEach(campana => {\n    texto += `• ${campana}\\n`;\n  });\n} else {\n  texto += \"• Ninguna.\\n\";\n}\n\ntexto += \"\\n**💡 Suggested Actions:**\\n\";\nif (suggestedActions.length > 0) {\n  suggestedActions.forEach((accion, index) => {\n    texto += `${index + 1}. ${accion}\\n`;\n  });\n} else {\n  texto += \"• Ninguna sugerencia.\\n\";\n}\n\nreturn [{\n  json: {\n    texto_discord: texto\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
